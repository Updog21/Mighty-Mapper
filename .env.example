# PostgreSQL Configuration
# Replace these values for your environment.
POSTGRES_USER=antikythera
POSTGRES_DB=antikythera
POSTGRES_PASSWORD=change_me
DATABASE_URL=postgresql://antikythera:change_me@db:5432/antikythera

# Session Configuration
# Generate a random secret: openssl rand -base64 32
SESSION_SECRET=change_me

# ======================
# DEPLOYMENT COMMANDS
# ======================
# After starting containers:
# 1. Run database migrations:
#    docker compose exec app npm run db:push
#
# 2. Seed the database with initial data:
#    docker compose exec app npx tsx scripts/seed_data.ts

# ======================
# POCKET ID & AUTH PROXY
# ======================
# Get these from your Pocket ID instance after setup.
POCKET_ID_CLIENT_ID=
POCKET_ID_CLIENT_SECRET=

# ======================
# CADDY / DOMAIN CONFIG
# ======================
# Your main domain for the application (e.g., mitre.example.com)
DOMAIN_NAME=example.com
# Your auth domain (e.g., auth.example.com)
AUTH_DOMAIN=auth.example.com
# Email for Let's Encrypt notifications
ACME_EMAIL=admin@example.com

# Pangolin Configuration
ENCRYPTION_KEY=change_me
JWT_SECRET=change_me
