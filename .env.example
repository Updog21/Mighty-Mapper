# PostgreSQL Configuration
# Replace these values for your environment.
POSTGRES_USER=antikythera
POSTGRES_DB=antikythera
POSTGRES_PASSWORD=change_me
DATABASE_URL=postgresql://antikythera:change_me@db:5432/antikythera

# Session Configuration
# Generate a random secret: openssl rand -base64 32
SESSION_SECRET=change_me

# Controls whether the session cookie requires HTTPS. For local HTTP, set to false.
# In production behind HTTPS, set to true (default if unset in production).
COOKIE_SECURE=false

# Comma-separated list of allowed origins for CORS.
# Example for local dev: http://localhost:5000,http://localhost:5173
ALLOWED_ORIGINS=http://localhost:5000,http://localhost:5173

# ======================
# DEPLOYMENT COMMANDS
# ======================
# After starting containers:
# 1. Run database migrations:
#    docker compose exec app npm run db:push
#
# 2. Seed the database with initial data:
#    docker compose exec app npx tsx scripts/seed_data.ts

# ENCRYPTION
ENCRYPTION_KEY=change_me

# ======================
# APPLICATION SETTINGS
# ======================

# Server port (defaults to 5000 if unset)
PORT=5000

# AI Provider selection and keys (provider: gemini|openai)
AI_PROVIDER=gemini

# Gemini configuration
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# Optional Gemini data-component mapping pipeline controls
GEMINI_DC_PIPELINE_MODE=balanced
GEMINI_DC_CACHE_ENABLED=true
GEMINI_DC_CACHE_TTL=10m
GEMINI_DC_POLICY_VERSION=v1
GEMINI_DC_REQUIRE_LEGACY_PARITY=true

# OpenAI configuration
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Optional: Override MITRE STIX source (defaults to GitHub ATT&CK v18)
MITRE_STIX_URL=
# Or point at a Workbench instance JSON export
MITRE_WORKBENCH_STIX_URL=

# Detections index tuning
DETECTIONS_INDEX_TTL_MS=600000
DETECTIONS_SEARCH_MODE=index
